{
  "name": "reabiclinic-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "migrate": "npm run typeorm migration:run",
    "seed": "npx ts-node src/database/seeders/cria-usuarios.ts",
    "prestart": "npm run migrate",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --maxWorkers=2",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs --dataSource src/database/data-source-cli.ts",
    "dockerbuild": "docker build --no-cache . -t  sa-saopaulo-1.ocir.io/grokrp4pglkm/api-reabi:v$npm_package_version",
    "dockerpush": "docker push sa-saopaulo-1.ocir.io/grokrp4pglkm/api-reabi:v$npm_package_version",
    "deploy": "npm run dockerbuild && npm run dockerpush",
    "deploy:homolog": "npm run deploy && docker tag sa-saopaulo-1.ocir.io/grokrp4pglkm/api-reabi:v$npm_package_version sa-saopaulo-1.ocir.io/grokrp4pglkm/api-reabi:homolog && docker push sa-saopaulo-1.ocir.io/grokrp4pglkm/api-reabi:homolog"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.1",
    "@nestjs/cache-manager": "2.0.1",
    "@nestjs/common": "^9.4.3",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^9.4.3",
    "@nestjs/jwt": "10.1.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^9.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^9.0.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.21.2",
    "cache-manager": "5.2.3",
    "cache-manager-redis-yet": "4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "google-auth-library": "^9.15.0",
    "googleapis": "^144.0.0",
    "ioredis": "^5.4.1",
    "moment": "^2.30.1",
    "oci-common": "^2.96.0",
    "oci-objectstorage": "^2.96.0",
    "pg": "^8.9.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.2.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "typeorm-extension": "^3.6.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.0.0",
    "@nestjs/schematics": "^9.0.0",
    "@nestjs/testing": "^9.4.3",
    "@testcontainers/postgresql": "^10.13.2",
    "@testcontainers/redis": "^10.13.2",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.13",
    "@types/ioredis": "^5.0.0",
    "@types/jest": "28.1.8",
    "@types/multer": "^1.4.12",
    "@types/node": "^16.0.0",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jest": "^28.1.3",
    "jest-mock-extended": "^4.0.0-beta1",
    "jest-sonar": "^0.2.16",
    "prettier": "^2.3.2",
    "sonarqube-scanner": "^4.0.1",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "28.0.8",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "4.1.0",
    "typescript": "^4.7.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
